generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Vendedores ───────────────────────────────────────────────
model Vendor {
  id                   Int        @id @default(autoincrement())
  nombre               String
  telefono             String     @unique
  role                 Role       @default(VENDOR)
  activo               Boolean    @default(true)
  instanciaEvolution   String?
  whatsappNumber       String?    @unique
  pin                  String?    @default("0000")
  campaigns            Campaign[]
  leads                Lead[]
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@map("vendors")
}

enum Role {
  ADMIN
  VENDOR
}

// ─── Campañas ─────────────────────────────────────────────────
model Campaign {
  id        Int        @id @default(autoincrement())
  slug      String     @unique
  nombre    String
  activa    Boolean    @default(true)
  vendorId  Int
  vendor    Vendor     @relation(fields: [vendorId], references: [id])
  triggers  Trigger[]
  steps     FlowStep[]
  leads     Lead[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("campaigns")
}

// ─── Triggers ─────────────────────────────────────────────────
model Trigger {
  id         Int      @id @default(autoincrement())
  texto      String
  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("triggers")
}

// ─── Pasos del flujo ──────────────────────────────────────────
model FlowStep {
  id          Int      @id @default(autoincrement())
  orden       Int
  tipo        StepType
  mensaje     String   @db.Text
  followupHrs Int?
  campaignId  Int
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, orden])
  @@map("flow_steps")
}

enum StepType {
  MSG
  FOLLOWUP
  NOTIFY
}

// ─── Leads ────────────────────────────────────────────────────
model Lead {
  id                Int        @id @default(autoincrement())
  telefono          String     @unique
  campaignId        Int?
  campaign          Campaign?  @relation(fields: [campaignId], references: [id])
  vendorId          Int?
  vendor            Vendor?    @relation(fields: [vendorId], references: [id])
  pasoActual        Int        @default(0)
  ultimoMensaje     DateTime?
  notificado        Boolean    @default(false)
  estado            LeadEstado @default(NUEVO)
  nombreDetectado   String?
  productoDetectado String?
  mensajes          Message[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("leads")
}

enum LeadEstado {
  NUEVO
  EN_FLUJO
  NOTIFICADO
  CERRADO
}

// ─── Historial de mensajes ────────────────────────────────────
model Message {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id])
  origen    String   // LEAD | BOT | VENDEDOR — TEXT en DB
  texto     String   @db.Text
  createdAt DateTime @default(now())

  @@map("messages")
}

